# Copy this file to .env and fill in the values before running `docker compose up`.
# .env is git-ignored — never commit the real file.

# REQUIRED: JWT signing key.  Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
JWT_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# OPTIONAL overrides (defaults shown):
# FRONTEND_PORT=80          # host port the app is served on  →  http://localhost
# FRONTEND_ORIGIN=http://localhost   # value sent in CORS allow-list
